# ─── Required (3 variables — that's all you need to start) ───
BOT_TOKEN=123456:your-telegram-bot-token       # from @BotFather
OPENAI_API_KEY=sk-your-openai-key
ADMIN_ID=123456789                             # your Telegram user ID (@userinfobot)

# ─── Optional (defaults work for local development) ───
# DATABASE_URL=postgresql://bot:bot@localhost:5432/bot    # default: sqlite:///./bot.db
# REDIS_URL=redis://localhost:6379/0
# OPENAI_MODEL=gpt-4o-mini
# DEBUG=False
# LOG_LEVEL=INFO
